# .env.example
# Copy file này thành .env và điền thông tin Azure của bạn

# ===== Azure Form Recognizer (Module 2) =====
AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_FORM_RECOGNIZER_KEY=your_api_key_here

# ===== Azure Text Analytics (Module 4) =====
AZURE_TEXT_ANALYTICS_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_TEXT_ANALYTICS_KEY=your_api_key_here

# ===== Feature Flags =====
USE_AZURE=false  # Set to true when you have Azure account
USE_LOCAL_FALLBACK=true  # Always use local models as fallback

# ===== Application Settings =====
DEBUG_MODE=true
LOG_LEVEL=INFO

# ===== Note =====
# Để lấy Azure credentials:
# 1. Truy cập https://portal.azure.com
# 2. Tạo "Cognitive Services" resource
# 3. Copy Endpoint và Key
# 4. Azure có Free Tier (1000 transactions/month)
